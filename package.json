{
  "name": "six-realms-rts",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "sim:determinism": "tsx scripts/sim_determinism.ts",
    "sim:match": "tsx scripts/sim_match.ts",
    "sim:smoke": "tsx scripts/sim_smoke.ts",
    "sim:gauntlet": "tsx scripts/sim_gauntlet.ts",
    "sim:3v3": "tsx scripts/sim_3v3.ts",
    "e2e": "playwright test",
    "ship": "npm run typecheck && npm run lint && npm run test && vite build"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  }
}
